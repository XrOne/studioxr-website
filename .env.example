# Sanity — récupérer le projectId sur https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production

# Token d'API Sanity (créer un token avec scope "Editor" ou "Viewer" pour la lecture)
# Ne JAMAIS exposer côté client, utilisé uniquement par les fetch serveur
SANITY_API_TOKEN=

# URL publique du site (utilisée pour metadata, sitemap, OG images)
NEXT_PUBLIC_SITE_URL=https://studioxr.one
